<?xml version="1.0"?>
<robot name="puzzlebot">
  <link name="base_footprint"/>

  <!--LINKS-->
  
  <link name="base_link">
    <visual>
      <geometry><mesh filename="package://puzzlebot_sim/meshes/Puzzlebot_Jetson_Lidar_Edition_Base.stl"/></geometry>
      <material name="yellow"><color rgba="0.8 0.7 0.0 1.0"/></material>
    </visual>
  </link>

  <link name="wheel_r">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><mesh filename="package://puzzlebot_sim/meshes/Puzzlebot_Wheel.stl"/></geometry>
      <material name="red"><color rgba="1.0 0 0 1.0"/></material>
    </visual>
  </link>

  <link name="wheel_l">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><mesh filename="package://puzzlebot_sim/meshes/Puzzlebot_Wheel.stl"/></geometry>
      <material name="blue"><color rgba="0 0 1.0 1.0"/></material>
    </visual>
  </link>

  <link name="caster">
    <visual>
      <geometry><mesh filename="package://puzzlebot_sim/meshes/Puzzlebot_Caster_Wheel.stl"/></geometry>
    </visual>
  </link>

  <!--JOINTS-->

  <joint name="base_link_joint" type="fixed">
    <origin xyz="0.0 0.0 0.05" rpy="0.0 0.0 0.0"/>
    <parent link="base_footprint"/>
    <child link="base_link"/>
  </joint>

  <joint name="wheel_r_joint" type="continuous">
    <origin xyz="0.052 -0.095 -0.0025" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="wheel_r"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="wheel_l_joint" type="continuous">
    <origin xyz="0.052 0.095 -0.0025" rpy="0 0 0"/> 
    <parent link="base_link"/>
    <child link="wheel_l"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="caster_joint" type="fixed">
    <origin xyz="-0.095 0.0 -0.03" rpy="0.0 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="caster"/>
  </joint>

</robot>
